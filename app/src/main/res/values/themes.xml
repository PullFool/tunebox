<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Tunebox" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/green_spotify</item>
        <item name="colorPrimaryVariant">@color/green_spotify_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/green_spotify</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/surface_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="TuneboxDialogTheme" parent="ThemeOverlay.Material3.Dialog.Alert">
        <item name="colorPrimary">@color/green_spotify</item>
        <item name="android:background">@color/surface_dark</item>
        <item name="android:textColor">@color/white</item>
    </style>

</resources>
